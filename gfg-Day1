1. Missing number in an array

class Solution {
    int missingNum(int arr[]) {
        long sum=0;
        for(int i=0;i<arr.length;i++){
            sum+=arr[i];
        }
         int n=arr.length+1;
         long actualsum=(long)n*(n+1)/2;
         return (int)(actualsum-sum);
    }
}

