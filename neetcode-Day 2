2) You are given an integer array nums of length n. Create an array ans of length 2n where ans[i] == nums[i] and ans[i + n] == nums[i] for 0 <= i < n (0-indexed).
Specifically, ans is the concatenation of two nums arrays.
Return the array ans.

Example 1:

Input: nums = [1,4,1,2]

Output: [1,4,1,2,1,4,1,2]


class Solution {
    public int[] getConcatenation(int[] nums) {
        int ans[]=new int[nums.length+nums.length];
        int ind=0;
        for(int i=0;i<nums.length;i++){
          ans[ind]=nums[i];
          ans[ind+nums.length]=nums[i];
          ind++;
        }
        return ans;
    }
}

